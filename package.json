{
  "name": "keinen-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install-all": "npm install",
    "client": "npm start --workspace=client",
    "server": "npm start --workspace=server",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "clean": "Stop-Process -Id (Get-NetTCPConnection -LocalPort 3050,8050 -ErrorAction SilentlyContinue).OwningProcess -Force"
  },
  "devDependencies": {
    "concurrently": "^8.0.1"
  }
}
